{
  "name": "frametrail-extension",
  "description": "Record clicks and generate step-by-step annotated image guides",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:headed": "pnpm build && PW_HEADED=1 playwright test",
    "test:all": "pnpm test && pnpm test:e2e",
    "postinstall": "wxt prepare",
    "validate:artifacts": "node tests/build/validate-browser-artifacts.mjs",
    "lint:firefox": "node tests/build/validate-firefox-lint.mjs",
    "test:e2e:firefox": "pnpm build:firefox && node tests/e2e/firefox-smoke.mjs",
    "test:e2e:browsers": "pnpm test:e2e && pnpm test:e2e:firefox",
    "test:e2e:docker": "docker build -f Dockerfile.e2e -t frametrail-extension-e2e . && mkdir -p test-results && docker run --rm --init --ipc=host -v \"$PWD/test-results:/work/extension/test-results\" frametrail-extension-e2e",
    "validate:architecture": "node tests/build/validate-module-boundaries.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.3",
    "idb": "^8.0.3",
    "lucide-react": "^1.24.0",
    "pdf-lib": "^1.17.1",
    "radix-ui": "^1.6.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "web-ext": "10.4.0",
    "wxt": "^0.20.27"
  },
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=20.19.0"
  },
  "pnpm": {
    "overrides": {
      "shell-quote": "1.9.0",
      "tmp": "0.2.7",
      "adm-zip": "0.6.0",
      "uuid": "11.1.1",
      "esbuild": "0.28.1"
    }
  }
}
